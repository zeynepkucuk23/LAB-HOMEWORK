digraph ShoppingSystem {
    node [shape=rectangle, style=filled, color=lightblue];
    
    Start [shape=oval, label="Start"];
    ShowProducts [label="Display Product List"];
    InputProduct [label="User Selects Product or 'Exit'"];
    CheckExit [shape=diamond, label="Is Input 'Exit'?"];
    CheckExists [shape=diamond, label="Product Exists?"];
    AddToCart [label="Add Product to Cart"];
    CalculateTotal [label="Calculate Total Cost"];
    ShowReceipt [label="Display Receipt & Total"];
    End [shape=oval, label="End"];

    Start -> ShowProducts;
    ShowProducts -> InputProduct;
    InputProduct -> CheckExit;
    
    CheckExit -> CheckExists [label="No"];
    CheckExit -> CalculateTotal [label="Yes"];
    
    CheckExists -> AddToCart [label="Yes"];
    CheckExists -> ShowProducts [label="No (Invalid)"];
    
    AddToCart -> ShowProducts;
    CalculateTotal -> ShowReceipt;
    ShowReceipt -> End;
}
