digraph HospitalSystem {
    rankdir=TB;
    node [shape=rectangle, fontname="Arial", style=rounded];

    Start [shape=oval, label="Start"];
    Auth [label="Patient Authentication"];
    IsRegistered [shape=diamond, label="Registered?"];
    Register [label="New Patient Registration"];
    
    Menu [label="Main Menu\n(Schedule, Records, Exit)"];
    
    Schedule [label="Select Department"];
    DocCheck [shape=diamond, label="Doctor Available?"];
    Book [label="Select Slot & Book"];
    NoDoc [label="Show Availability Error"];
    
    Records [label="Display Medical History"];
    Exit [shape=oval, label="Logout & End"];

    Start -> Auth;
    Auth -> IsRegistered;
    IsRegistered -> Menu [label="YES"];
    IsRegistered -> Register [label="NO"];
    Register -> Menu;
    
    Menu -> Schedule;
    Schedule -> DocCheck;
    DocCheck -> Book [label="YES"];
    DocCheck -> NoDoc [label="NO"];
    
    Book -> Menu;
    NoDoc -> Menu;
    
    Menu -> Records;
    Records -> Menu;
    
    Menu -> Exit;
}
